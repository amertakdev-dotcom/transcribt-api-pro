# =====================
# Node.js Service
# =====================
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# MongoDB (required for job queue)
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/transcribe?retryWrites=true&w=majority

# Python AI Service URL
AI_SERVICE_URL=http://localhost:8000

# Worker poll interval (ms)
WORKER_POLL_INTERVAL=3000

# =====================
# Redis (optional — for BullMQ)
# =====================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379